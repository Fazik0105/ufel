#: championship/views.py:2494
msgid "Uzbekistan Football e-League — REGLAMENT"
msgstr "Uzbekistan Football e-League — REGLAMENT"

#: championship/views.py:2497
msgid "1. UMUMIY MA’LUMOT"
msgstr "1. UMUMIY MA'LUMOT"

#: championship/views.py:2499
msgid ""
"1.1. UFEL (Uzbekistan Football e-League) — eFootball o'yinida turnirlar "
"tashkil qiluvchi liga hisoblanadi."
msgstr "1.1. UFEL (Uzbekistan Football e-League) — eFootball o'yinida turnirlar tashkil qiluvchi liga hisoblanadi."

#: championship/views.py:2500
msgid ""
"1.2. Turnirlar eFootball oʻyini asosida va ushbu reglamentga muvofiq tashkil "
"etiladi."
msgstr "1.2. Turnirlar eFootball oʻyini asosida va ushbu reglamentga muvofiq tashkil etiladi."

#: championship/views.py:2501
msgid "1.3. Ushbu reglament barcha ishtirokchilar uchun majburiy hisoblanadi."
msgstr "1.3. Ushbu reglament barcha ishtirokchilar uchun majburiy hisoblanadi."

#: championship/views.py:2502
msgid ""
"1.4. Liga maqsadi — eFootballni O'zbekistonda yangi darajada rivojlantirish "
"va kuchli raqobat muhitini taʼminlash."
msgstr "1.4. Liga maqsadi — eFootballni O'zbekistonda yangi darajada rivojlantirish va kuchli raqobat muhitini taʼminlash."

#: championship/views.py:2506
msgid "2. ISHTIROKCHILAR"
msgstr "2. ISHTIROKCHILAR"

#: championship/views.py:2508
msgid "2.1. Ligada roʻyxatdan oʻtgan barcha ishtirokchilar qatnashishi mumkin."
msgstr "2.1. Ligada roʻyxatdan oʻtgan barcha ishtirokchilar qatnashishi mumkin."

#: championship/views.py:2509
msgid ""
"2.2. Adminlar ishtirokchilardan turnir uchun kerakli bo'lgan malumotlarni "
"sorashi mumkun."
msgstr "2.2. Adminlar ishtirokchilardan turnir uchun kerakli bo'lgan ma'lumotlarni so'rashi mumkin."

#: championship/views.py:2510
msgid ""
"2.3. Bir ishtirokchi turnirlarda faqat bitta akkaunt orqali qatnashishi "
"mumkin."
msgstr "2.3. Bir ishtirokchi turnirlarda faqat bitta akkaunt orqali qatnashishi mumkin."

#: championship/views.py:2514
msgid "3. TEXNIK TALABLAR"
msgstr "3. TEXNIK TALABLAR"

#: championship/views.py:2516
msgid "3.1. Platformalar: PlayStation 4/5, Kompyuter (PC), Xbox."
msgstr "3.1. Platformalar: PlayStation 4/5, Kompyuter (PC), Xbox."

#: championship/views.py:2517
msgid ""
"3.2. Barqaror o‘yin uchun internet ulanishi LAN (simli) tarmoq tavsiya "
"etiladi."
msgstr "3.2. Barqaror o‘yin uchun internet ulanishi LAN (simli) tarmoq tavsiya etiladi."

#: championship/views.py:2518
msgid ""
"3.3. Ishtirokchining internet tezligi pas yoki ulanishi belgilangan texnik "
"talablarga mos kelmagan hollarda, turnirdan chetlatiladi."
msgstr "3.3. Ishtirokchining internet tezligi past yoki ulanishi belgilangan texnik talablarga mos kelmagan hollarda, turnirdan chetlatiladi."

#: championship/views.py:2519
msgid ""
"3.4. Match Sozlamalari turnir turiga qarab alohida reglament yoki eʼlonda "
"belgilanadi."
msgstr "3.4. Match sozlamalari turnir turiga qarab alohida reglament yoki eʼlonda belgilanadi."

#: championship/views.py:2520
msgid ""
"3.5. O'yin davomida internet uzilishi yoki texnik nosozliklar yuzaga kelsa, "
"hakamlar qarori bilan qayta o'ynash yoki hisobni saqlab qolish masalasi "
"ko'rib chiqiladi."
msgstr "3.5. O'yin davomida internet uzilishi yoki texnik nosozliklar yuzaga kelsa, hakamlar qarori bilan qayta o'ynash yoki hisobni saqlab qolish masalasi ko'rib chiqiladi."

#: championship/views.py:2524
msgid "4. O‘YINNI BOSHLASH TARTIBI"
msgstr "4. O‘YINNI BOSHLASH TARTIBI"

#: championship/views.py:2526
msgid ""
"4.1. O‘yinni boshlash uchun ishtirokchilar o‘zaro kelishgan holda qulay "
"vaqtni belgilaydi va bir-biri bilan bog‘lanadi."
msgstr "4.1. O‘yinni boshlash uchun ishtirokchilar o‘zaro kelishgan holda qulay vaqtni belgilaydi va bir-biri bilan bog‘lanadi."

#: championship/views.py:2527
msgid ""
"4.2. Agar raqib xabarlarga javob bermasa yoki kelishilgan vaqtda aloqaga "
"chiqmasa, UFEL adminlariga murojaat qilinadi."
msgstr "4.2. Agar raqib xabarlarga javob bermasa yoki kelishilgan vaqtda aloqaga chiqmasa, UFEL adminlariga murojaat qilinadi."

#: championship/views.py:2528
msgid ""
"4.3. Adminlar holatni ko‘rib chiqib, texnik g‘alaba, yoki boshqa yakuniy "
"qaror qabul qiladi."
msgstr "4.3. Adminlar holatni ko‘rib chiqib, texnik g‘alaba yoki boshqa yakuniy qaror qabul qiladi."

#: championship/views.py:2529
msgid "4.4. Kelishilgan o‘yinlar qat’iyan taqiqlanadi."
msgstr "4.4. Kelishilgan o‘yinlar qat’iyan taqiqlanadi."

#: championship/views.py:2533
msgid "5. LIGA JADVALINI HISOBLASH TARTIBI"
msgstr "5. LIGA JADVALINI HISOBLASH TARTIBI"

#: championship/views.py:2535
msgid ""
"5.1. Liga bosqichida ishtirokchilarning turnir jadvalidagi o‘rinlari, "
"to‘plangan ochkolar soni asosida aniqlanadi."
msgstr "5.1. Liga bosqichida ishtirokchilarning turnir jadvalidagi o‘rinlari, to‘plangan ochkolar soni asosida aniqlanadi."

#: championship/views.py:2536
msgid ""
"5.2. Agar ishtirokchilarning ochkolari teng bo‘lsa, ustunlik ko‘proq gol "
"urgan ishtirokchiga beriladi."
msgstr "5.2. Agar ishtirokchilarning ochkolari teng bo‘lsa, ustunlik ko‘proq gol urgan ishtirokchiga beriladi."

#: championship/views.py:2537
msgid ""
"5.3. Agar ochkolar va urilgan gollar soni ham teng bo‘lsa, ustunlik kamroq "
"gol o‘tkazib yuborgan ishtirokchiga beriladi."
msgstr "5.3. Agar ochkolar va urilgan gollar soni ham teng bo‘lsa, ustunlik kamroq gol o‘tkazib yuborgan ishtirokchiga beriladi."

#: championship/views.py:2538
msgid ""
"5.4. Agar yuqoridagi barcha ko‘rsatkichlar teng bo‘lib qolsa, "
"ishtirokchilarning o‘zaro o‘yin natijasi hisobga olinadi."
msgstr "5.4. Agar yuqoridagi barcha ko‘rsatkichlar teng bo‘lib qolsa, ishtirokchilarning o‘zaro o‘yin natijasi hisobga olinadi."

#: championship/views.py:2539
msgid ""
"5.5. Maxsus formatdagi turnirlarda (JCH, CHL va boshqa) turnirlarda jadvalni "
"hisoblash tartibi ushbu turnir reglamentida alohida belgilanadi."
msgstr "5.5. Maxsus formatdagi turnirlarda (JCH, CHL va boshqa) turnirlarda jadvalni hisoblash tartibi ushbu turnir reglamentida alohida belgilanadi."

#: championship/views.py:2543
msgid "6. INTIZOM"
msgstr "6. INTIZOM"

#: championship/views.py:2545
msgid ""
"6.1. Turnir davomida barcha ishtirokchilar o‘zaro hurmat va sport ruhiga "
"amal qilishlari tavsiya etiladi."
msgstr "6.1. Turnir davomida barcha ishtirokchilar o‘zaro hurmat va sport ruhiga amal qilishlari tavsiya etiladi."

#: championship/views.py:2546
msgid ""
"6.2. Guruhda Haqorat, tahdid yoki boshqa nojo‘ya xatti harakatlar "
"ogohlantirish yoki Ban ga sabab bo‘ladi."
msgstr "6.2. Guruhda haqorat, tahdid yoki boshqa nojo‘ya xatti harakatlar ogohlantirish yoki bangacha sabab bo‘ladi."

#: championship/views.py:2550
msgid "7. YAKUNIY QOIDALAR"
msgstr "7. YAKUNIY QOIDALAR"

#: championship/views.py:2552
msgid ""
"7.1. Ishtirokchi turnirda qatnashish orqali ushbu reglamentni to‘liq qabul "
"qilgan hisoblanadi."
msgstr "7.1. Ishtirokchi turnirda qatnashish orqali ushbu reglamentni to‘liq qabul qilgan hisoblanadi."

#: championship/views.py:2553
msgid "7.2. UFEL adminlari bahsli vaziyatlarda yakuniy qaror qabul qiladi."
msgstr "7.2. UFEL adminlari bahsli vaziyatlarda yakuniy qaror qabul qiladi."

#: championship/views.py:2554
msgid ""
"7.3. Adminlar reglamentga o‘zgartirish va qo‘shimchalar kiritish huquqini "
"o‘zida saqlab qoladi."
msgstr "7.3. Adminlar reglamentga o‘zgartirish va qo‘shimchalar kiritish huquqini o‘zida saqlab qoladi."

